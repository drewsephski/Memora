# =============================================================================
# Web app (Next.js) — copy to .env.local and fill in values
# cp apps/web/.env.sample apps/web/.env.local
# =============================================================================

# --- App URLs ---
# Local: http://localhost:3000 / http://localhost:3001
# Production: https://memoralabs.dev / https://api.memoralabs.dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Supabase (from `supabase start` output OR Supabase dashboard → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PROJECT_ID=
SUPABASE_SERVICE_ROLE_KEY=

# --- OpenRouter (openrouter.ai/keys — used for embeddings + chat) ---
OPENROUTER_API_KEY=
# OPENROUTER_CHAT_MODEL=google/gemini-2.0-flash
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Stripe (dashboard.stripe.com → Developers → API keys + Products/Prices) ---
STRIPE_SECRET_KEY=
STRIPE_SIGNATURE_SECRET=
NEXT_PUBLIC_STRIPE_KEY=
NEXT_PUBLIC_STRIPE_PRODUCT_BASIC=
NEXT_PUBLIC_STRIPE_PRODUCT_ENTERPRISE=
NEXT_PUBLIC_STRIPE_PRICE_BASIC_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_BASIC_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ENTERPRISE_YEARLY=

# --- PostHog (posthog.com → Project Settings → Project API Key) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Loops email (app.loops.so → Settings → API key) ---
LOOPS_API_KEY=

# --- Internal secrets (generate with: openssl rand -hex 32) ---
API_ROUTE_SECRET=
DEMO_SUPA_API_KEY=
MEMORA_API_KEY=

# --- Analytics (optional for local dev — any non-empty string works) ---
NEXT_PUBLIC_GOOGLE_ANALYTICS=G-LOCALDEV

# --- Optional: example/demo routes that call the API server ---
# MEMORA_API_URL=http://localhost:3001

# --- Optional: AI citations middleware tracking ---
# AI_CITATIONS_PROJECT_ID=
