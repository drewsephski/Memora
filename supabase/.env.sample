# =============================================================================
# Supabase CLI / Edge Functions — copy to .env
# cp supabase/.env.sample supabase/.env
# =============================================================================

# Shared secret for database webhooks → /api/init-new-user and edge functions
# Generate with: openssl rand -hex 32
# Must match API_ROUTE_SECRET in apps/web/.env.local
API_ROUTE_SECRET=

# --- Google OAuth (Supabase Auth → Providers → Google) ---
# Local redirect URI: http://127.0.0.1:54321/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
SUPABASE_AUTH_EXTERNAL_GOOGLE_REDIRECT_URI=http://127.0.0.1:54321/auth/v1/callback

# --- Optional: weekly Discord report edge function ---
DISCORD_BOT_TOKEN=

# --- Optional: Loops (reset-api-usage edge function) ---
LOOPS_API_KEY=
