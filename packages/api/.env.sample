# =============================================================================
# API server — copy to .env and fill in values
# cp packages/api/.env.sample packages/api/.env
# =============================================================================

PORT=3001

# --- OpenRouter (openrouter.ai/keys — used for embeddings + chat) ---
OPENROUTER_API_KEY=
# OPENROUTER_CHAT_MODEL=google/gemini-2.0-flash
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Supabase (same project as web app; use service role key, not anon key) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Upstash Redis (console.upstash.com → create DB → REST API) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- PostHog (optional but recommended) ---
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# --- Stripe product IDs (must match web app — used for usage tier limits) ---
NEXT_PUBLIC_STRIPE_PRODUCT_BASIC=
NEXT_PUBLIC_STRIPE_PRODUCT_ENTERPRISE=

# --- Loops (optional — used by some API-side integrations) ---
LOOPS_API_KEY=

# --- Local dev: skip Upstash rate limiting if Redis isn't set up yet ---
# RATE_LIMIT_DISABLED=true

# --- Semantic cache (optional overrides) ---
# ENABLE_SEMANTIC_CACHE=true
# CACHE_L1_TTL=3600
# CACHE_L2_TTL=86400
# CACHE_SEMANTIC_THRESHOLD=0.95
